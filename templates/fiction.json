{
  "templates": [
    {
      "id": "novel",
      "name": "Novel",
      "description": "Classic novel format with elegant serif fonts",
      "category": "Fiction",
      "icon": "📖",
      "styles": {
        "fontFamily": "Crimson Pro",
        "fontSize": 12,
        "lineHeight": 1.8,
        "textAlign": "justify",
        "pageSize": "6x9",
        "firstLineIndent": "1.5em"
      },
      "sections": [
        { "type": "title-page", "title": "Title Page" },
        { "type": "copyright", "title": "Copyright" },
        { "type": "dedication", "title": "Dedication" },
        { "type": "toc", "title": "Table of Contents" },
        { "type": "chapter", "title": "Chapter 1" }
      ],
      "sampleContent": "<h1>{{title}}</h1><p style='text-align:center'>A Novel by {{author}}</p>"
    },
    {
      "id": "short-story",
      "name": "Short Story",
      "description": "Compact format for short fiction",
