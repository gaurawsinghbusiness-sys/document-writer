{
  "templates": [
    {
      "id": "report",
      "name": "Report Writing",
      "description": "Professional report format with clean structure",
      "category": "Non-Fiction",
      "icon": "📊",
      "styles": {
        "fontFamily": "Inter",
        "fontSize": 11,
        "lineHeight": 1.5,
        "textAlign": "left",
        "pageSize": "8.5x11",
        "firstLineIndent": "0"
      },
      "sections": [
        { "type": "cover", "title": "Cover Page" },
        { "type": "executive-summary", "title": "Executive Summary" },
        { "type": "toc", "title": "Table of Contents" },
        { "type": "introduction", "title": "1. Introduction" },
        { "type": "methodology", "title": "2. Methodology" },
        { "type": "findings", "title": "3. Findings" },
        { "type": "conclusion", "title": "4. Conclusion" },
        { "type": "references", "title": "References" },
        { "type": "appendix", "title": "Appendix" }
      ],
      "sampleContent": "<h1 style='text-align:center;margin-top:3in'>{{title}}</h1><p style='text-align:center;margin-top:1em'>Prepared by: {{author}}</p><p style='text-align:center'>{{date}}</p>"
    },
    {
